    plt.show()


# ============================================================
# Generate and export figures
# ============================================================

for date_value in sorted(merged["Date"].unique()):

    day_df = merged[merged["Date"] == date_value].copy()

    plot_mean_median(day_df, date_value)
    plot_percentile_range(day_df, date_value)
